# Mistral
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# Substack
# Your publication URL e.g. https://yourname.substack.com
SUBSTACK_PUBLICATION_URL=https://yourname.substack.com
# Get these from browser devtools → Application → Cookies → substack.com
SUBSTACK_SID=your_substack_sid_cookie_value
SUBSTACK_LLI=your_substack_lli_cookie_value

# Email (Gmail SMTP)
EMAIL_SENDER=your@gmail.com
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_APP_PASSWORD=your_16_char_app_password
